{
  "name": "drawing-renamer",
  "version": "1.0.0",
  "description": "CLI tool to automatically rename AutoCAD PDF drawings using a PDF drawing register.",
  "main": "main.js",
  "type": "commonjs",
  "bin": {
    "rename-drawings": "./renamer.js"
  },
  "scripts": {
    "start": "node renamer.js",
    "start-gui": "neu run",
    "build-gui": "neu build",
    "dist": "electron-builder --win --x64"
  },
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=16"
  },
  "build": {
    "appId": "com.yourcompany.drawingrenamer",
    "productName": "DrawingRenamer",
    "files": ["**/*"],
    "directories": { "output": "dist" },
    "icon": "build/icon.ico",
    "win": {
      "target": ["portable"]
    },
    "publish": null
  }
}
